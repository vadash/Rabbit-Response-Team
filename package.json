{
  "name": "rabbit-response-team",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SillyTavern extension — offline random-word injection to disrupt LLM patterns",
  "scripts": {
    "build": "node scripts/build_assets.js && node scripts/verify_assets.js",
    "verify": "node scripts/verify_assets.js",
    "test": "node --test \"tests/**/*.test.js\"",
    "repomix": "repomix --config repomix.config.json --output repomix-output.md",
